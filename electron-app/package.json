{
  "name": "mirrorbeam",
  "version": "1.0.0",
  "description": "MirrorBeam - Screen Mirroring for iPhone (AirPlay Receiver for PC)",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win nsis",
    "build:portable": "electron-builder --win portable",
    "build:store": "electron-builder --win appx --config electron-builder-appx.json",
    "dev": "electron . --dev"
  },
  "author": "Tôm AI",
  "license": "MIT",
  "devDependencies": {
    "electron": "^42.5.0",
    "electron-builder": "^25.0.0"
  },
  "build": {
    "appId": "com.tom.mirrorbeam",
    "productName": "MirrorBeam",
    "publish": [
      {
        "provider": "github",
        "owner": "sachnoikhoinghiep-cell",
        "repo": "MirrorBeam"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "icon.png"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "artifactName": "MirrorBeam-Setup-${version}.exe"
    },
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "licenses.html",
      "icon.png",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../uxplay-src/build/uxplay.exe",
        "to": "uxplay.exe"
      },
      {
        "from": "window-styler.ps1",
        "to": "window-styler.ps1"
      },
      {
        "from": "licenses",
        "to": "licenses"
      },
      {
        "from": "gstreamer",
        "to": "gstreamer"
      },
      {
        "from": "redist",
        "to": "redist"
      }
    ]
  },
  "dependencies": {
    "electron-updater": "^6.8.9"
  }
}
